BOT_TOKEN=
APP_ID=
DATABASE_URL=
DZZ_HOST="localhost"
DZZ_PORT="5432"
DZZ_USER="exampleUser"
DZZ_PASSWORD="example"
DZZ_DATABASE="exampleDb"

NODE_ENV=development

# Run cleanup at a fixed clock hour (0-23, e.g. 5 = 05:00). Takes priority over RATE_LIMIT_CLEANUP_HOURS.
# RATE_LIMIT_CLEANUP_HOUR=5

# Run cleanup every N hours from bot startup. Default: 24. Ignored if RATE_LIMIT_CLEANUP_HOUR is set.
RATE_LIMIT_CLEANUP_HOURS=24
